<%- include('../partials/header') %>

<style>
    .movie-list {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
        padding: 2rem;
        background-color: #f8f9fa;
    }

    .movie-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        overflow: hidden;
        transition: transform 0.2s ease-in-out;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .movie-image {
        width: 100%;
        height: 300px;
        object-fit: cover;
    }

    .movie-details {
        padding: 1rem;
        flex-grow: 1;
    }

    .movie-title {
        font-size: 1.25rem;
        font-weight: bold;
        margin-bottom: 0.5rem;
    }

    .movie-genre,
    .movie-rating {
        font-size: 0.95rem;
        color: #555;
    }

    .movie-rating {
        margin-top: 0.5rem;
    }

    .movie-actions {
        display: flex;
        justify-content: space-between;
        gap: 0.5rem;
        padding: 1rem;
        padding-top: 0;
    }

    .movie-actions form,
    .movie-actions a {
        flex: 1;
    }

    .btn {
        display: inline-block;
        width: 100%;
        padding: 0.5rem;
        text-align: center;
        border: none;
        border-radius: 6px;
        font-size: 0.9rem;
        cursor: pointer;
        background-color: #007bff;
        color: white;
        text-decoration: none;
    }

    .btn:hover {
        background-color: #0056b3;
    }

    .btn-secondary {
        background-color: #6c757d;
    }

    .btn-secondary:hover {
        background-color: #5a6268;
    }
</style>

<div class="movie-list">
    <% movies.forEach(movie => { %>
        <div class="movie-card">
            <img class="movie-image" src="<%= movie.imageURL %>" alt="<%= movie.title %> poster">
            <div class="movie-details">
                <div class="movie-title"><%= movie.title %></div>
                <div class="movie-genre">Genre: <%= movie.genre %></div>
                <div class="movie-rating">Rating: <%= movie.rating %>/10</div>
            </div>
            <div class="movie-actions">
                <form action="/favorites/toggle/<%= movie.id %>" method="POST">
                    <button class="btn <%= movie.isFavorite ? 'btn-secondary' : '' %>" type="submit">
                        <%= movie.isFavorite ? 'Remove Favorite' : 'Add to Favorites' %>
                    </button>
                </form>
                <a href="/review/view/<%= movie.id %>" class="btn">View Movie</a>
            </div>
        </div>
    <% }) %>
</div>

<%- include('../partials/footer') %>

